generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CategoryEvent {
  id        Int      @id @default(autoincrement())
  nama      String
  deskripsi String?
  events    Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pembicara {
  id        Int      @id @default(autoincrement())
  nama      String
  keahlian  String?
  email     String?
  events    Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          Int      @id @default(autoincrement())
  judul       String
  deskripsi   String?
  tanggal     DateTime
  lokasi      String

  categoryId  Int
  pembicaraId Int

  category    CategoryEvent @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  pembicara   Pembicara     @relation(fields: [pembicaraId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}